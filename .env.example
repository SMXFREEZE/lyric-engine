# Copy this to .env and fill in your values

# Genius API token (get from https://genius.com/api-clients)
GENIUS_TOKEN=your_genius_token_here

# Path to base model (defaults to gpt2 for local dev)
# For production: mistralai/Mistral-7B-Instruct-v0.2
LYRICS_MODEL_PATH=gpt2

# Path to trained PEFT/LoRA checkpoint directory
# e.g. checkpoints/genre_trap/epoch_3
CHECKPOINT_PATH=

# Optional: path to fine-tuned valence/arousal RoBERTa
VALENCE_MODEL_PATH=

# Inference settings
BEAM_SIZE=8

# Force single-GPU inference (set to 1 for Kaggle T4)
SINGLE_GPU=0

# Enable 4-bit quantisation (set to 0 to disable)
USE_4BIT=1

# HuggingFace token (needed to download gated base models like Mistral)
HUGGING_FACE_HUB_TOKEN=your_hf_token_here
