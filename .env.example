# Copy this to .env and fill in your values

# Genius API token (get from https://genius.com/api-clients)
GENIUS_TOKEN=your_genius_token_here

# Path to trained model (defaults to gpt2 for local dev)
# For production: meta-llama/Llama-3.1-8B or path to your fine-tuned checkpoint
LYRICS_MODEL_PATH=gpt2

# Optional: path to fine-tuned valence/arousal RoBERTa
VALENCE_MODEL_PATH=

# Inference settings
BEAM_SIZE=8

# HuggingFace token (needed to download Llama 3.1)
HUGGING_FACE_HUB_TOKEN=your_hf_token_here
